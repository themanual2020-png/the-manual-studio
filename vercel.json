{
  "buildCommand": "node scripts/inject-env.js",
  "outputDirectory": ".",
  "functions": {
    "api/project-meta.js": {
      "includeFiles": "_project-template.html"
    },
    "api/home-meta.js": {
      "includeFiles": "_home-template.html"
    },
    "api/about-meta.js": {
      "includeFiles": "_about-template.html"
    }
  },
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/project.html",
      "destination": "/api/project-meta"
    },
    {
      "source": "/",
      "destination": "/api/home-meta"
    },
    {
      "source": "/index.html",
      "destination": "/api/home-meta"
    },
    {
      "source": "/about.html",
      "destination": "/api/about-meta"
    }
  ]
}

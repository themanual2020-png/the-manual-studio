{
  "buildCommand": "node scripts/inject-env.js",
  "outputDirectory": ".",
  "functions": {
    "api/project-meta.js": {
      "includeFiles": "project.html"
    }
  },
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/project.html",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|Slackbot|TelegramBot|Line|Discordbot|Pinterest|redditbot).*"
        }
      ],
      "destination": "/api/project-meta"
    }
  ]
}
